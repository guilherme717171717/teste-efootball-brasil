# ===== VARIÁVEIS DE AMBIENTE - eFOOTBALL BRASIL =====
# Copie este arquivo para .env e preencha com seus dados

# Discord OAuth2 - https://discord.com/developers/applications
DISCORD_CLIENT_ID=seu_client_id_aqui
DISCORD_CLIENT_SECRET=seu_client_secret_aqui
DISCORD_REDIRECT_URI=http://localhost:3000/login-discord.html

# (Opcional) Para adicionar membros automaticamente ao servidor
DISCORD_GUILD_ID=1077324994373222500
DISCORD_BOT_TOKEN=seu_bot_token_aqui

# (Opcional) Webhook do Discord para receber notificações de tickets/denúncias/compras
DISCORD_WEBHOOK_URL=

# Credenciais do painel admin (usuário:senha, separados por vírgula)
ADMIN_USERS=admin:senha123,moderador:senha456

# Credenciais do painel de suporte
SUPPORT_USERS=suporte:senha789

# Servidor
PORT=3000
